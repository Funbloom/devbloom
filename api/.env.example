OPENAI_API_KEY=your_api_key_here

# Supabase (required for auth and existing features)
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# JWT secret: Supabase Dashboard > Project Settings > API > JWT Secret
# SUPABASE_JWT_SECRET=your_jwt_secret

# Auth: allowed email domains (comma-separated, e.g. funbloomstudio.com)
# ALLOWED_EMAIL_DOMAINS=funbloomstudio.com
# Admin emails (comma-separated) or set user_metadata.role = "admin" in Supabase for one user
# ADMIN_EMAILS=admin@funbloomstudio.com

# Usage: max images (Image Gen + storyboard tiles) per user per day. Admins are unlimited. Default 20.
# MAX_IMAGES_PER_USER_PER_DAY=20

# API base URL (e.g. for CORS or links). Set to your real server URL in production.
# The web app uses NEXT_PUBLIC_API_URL_BASE (in web/.env) set to the same value.
# API_URL_BASE=http://localhost:8000

# Optional: Supabase Storage bucket for storyboard tile images (sync across computers).
# Create a public bucket "storyboard-images" in Supabase Dashboard > Storage.
# STORYBOARD_IMAGES_BUCKET=storyboard-images
