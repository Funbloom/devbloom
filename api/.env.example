OPENAI_API_KEY=your_api_key_here
GOOGLE_SEARCH_ENGINE_ID=
OPENAI_API_KEY=
GNEWS_API_KEY=
LEONARDO_API_KEY=unused
#API Tools
CLIPDROP_API_KEY=<your key>
BKGROMOVALTECH=rembg

JIRA_API_TOKEN=
JIRA_BASE_URL=
JIRA_EMAIL=

# Supabase (required for auth and existing features)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# JWT secret: Supabase Dashboard > Project Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your_jwt_secret


###### SETTINGS ######
DOC_OUTPUT_DIR=Gen\DesignDocs
IMAGES_OUTPUT_DIR=Gen\Images

# Directory for chat histories (relative to project root or absolute).
# Default (if unset): .local_data/history
CHAT_HISTORY_DIR=.local_data/history

# Auth: allowed email domains (comma-separated, e.g. funbloomstudio.com)
ALLOWED_EMAIL_DOMAINS=funbloomstudio.com
# Admin emails (comma-separated) or set user_metadata.role = "admin" in Supabase for one user
ADMIN_EMAILS=admin@funbloomstudio.com

# Usage: max images (Image Gen + storyboard tiles) per user per day. Admins are unlimited. Default 20.
MAX_IMAGES_PER_USER_PER_DAY=80

# CORS: allowed frontend origins (comma-separated). Required on EC2 so the browser can call the API.
# Example: https://yourdomain.com,https://www.yourdomain.com
# Default (if unset): http://localhost:3000,http://127.0.0.1:3000
#CORS_ORIGINS=https://yourdomain.com


# API base URL (e.g. for links). The web app uses NEXT_PUBLIC_API_URL_BASE (in web/.env).
# API_URL_BASE=http://localhost:8000

# Optional: Supabase Storage bucket for storyboard tile images (sync across computers).
# Create a public bucket "storyboard-images" in Supabase Dashboard > Storage.
# STORYBOARD_IMAGES_BUCKET=storyboard-images

