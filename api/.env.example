OPENAI_API_KEY=your_api_key_here

# API base URL (e.g. for CORS or links). Set to your real server URL in production.
# The web app uses NEXT_PUBLIC_API_URL_BASE (in web/.env) set to the same value.
# API_URL_BASE=http://localhost:8000

# Optional: Supabase Storage bucket for storyboard tile images (sync across computers).
# Create a public bucket "storyboard-images" in Supabase Dashboard > Storage.
# STORYBOARD_IMAGES_BUCKET=storyboard-images
