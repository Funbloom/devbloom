{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    //
    // Both configs use the SHARED root .venv (one venv at the repo root for both
    // api and local_agent). Bootstrap it once via api/run.bat or local_agent/run.bat.
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: FastAPI",
            "cwd": "${workspaceFolder}/api",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "osx": {
                "python": "${workspaceFolder}/.venv/bin/python"
            },
            "linux": {
                "python": "${workspaceFolder}/.venv/bin/python"
            },
            "module": "uvicorn",
            "args": [
                "main:app",
                "--reload",
                "--port",
                "8000"
            ],
            "jinja": true
        },
        {
            "name": "Python Debugger: Local Agent",
            "cwd": "${workspaceFolder}",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "osx": {
                "python": "${workspaceFolder}/.venv/bin/python"
            },
            "linux": {
                "python": "${workspaceFolder}/.venv/bin/python"
            },
            "module": "uvicorn",
            "args": [
                "local_agent.main:app",
                "--host",
                "127.0.0.1",
                "--port",
                "8765"
            ]
        }
    ]
}
