# Segment Anything — UI Breakdown (`POST /ui_breakdown/sam`)
# Copy this file to `.env` in this folder (or create `.env` with the same keys).
# Checkpoints: https://github.com/facebookresearch/segment-anything#model-checkpoints

# Full path to the downloaded .pth file (required for SAM)
SAM_CHECKPOINT_PATH=

# Must match the checkpoint: vit_b | vit_l | vit_h
SAM_MODEL_TYPE=vit_b
