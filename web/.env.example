# API server URL (used by the Next.js app for all fetch() calls).
# Set to your real server IP or URL in production.
# Must be NEXT_PUBLIC_* to be available in the browser.
NEXT_PUBLIC_API_URL_BASE=http://localhost:8000

# Supabase (for login). Get from Dashboard > Project Settings > API.
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
