# Prefer `web/.env.local` for secrets (ignored by git). Alternatively you can copy this file to
# `web/env.local` — Next does not load that filename by itself, but `web/next.config.js` merges any
# keys from `env.local` that Next did not already set from `.env*`. Dot-prefixed files work fine on macOS.

# API server URL (used by the Next.js app for all fetch() calls).
# Set to your real server IP or URL in production.
# Must be NEXT_PUBLIC_* to be available in the browser.
NEXT_PUBLIC_API_URL_BASE=http://localhost:8000

# Local agent only (native folder picker, Mesh Gen, RAG file ops). NOT the same as NEXT_PUBLIC_API_URL_BASE.
# Default if unset: http://127.0.0.1:8765
# NEXT_PUBLIC_LOCAL_AGENT_URL=http://127.0.0.1:8765

# Mesh Gen uses Hunyuan3D-2 inside the local agent (no separate Hunyuan HTTP server).
# Install PyTorch/CUDA and Hunyuan3D-2 into the shared root .venv; optional env on the agent process:
# HUNYUAN_MODEL_PATH, HUNYUAN_SUBFOLDER, HUNYUAN_TEX_MODEL_PATH, HUNYUAN_DEVICE

# Supabase (for login). Dashboard → Project Settings → API — use anon / public JWT.
# Prefer NEXT_PUBLIC_* so values are explicit. If you use `web/env.local` with backend-style names instead,
# set SUPABASE_URL and SUPABASE_ANON_KEY; web/next.config.js maps them into NEXT_PUBLIC_* at build/runtime.
# Never use the service_role key in Next — only anon on the frontend.
#
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
