# Example systemd unit for DevBloom API (FastAPI).
# Copy to /etc/systemd/system/devbloom-api.service
# Replace APP_ROOT with your app directory (e.g. /home/ec2-user/devbloom) and USER if not ec2-user.
# Layout: APP_ROOT/api (this WorkingDirectory), APP_ROOT/games (manifest + game packages; required for imports).
# Then: sudo systemctl daemon-reload && sudo systemctl enable --now devbloom-api

[Unit]
Description=DevBloom API
After=network.target

[Service]
Type=simple
User=ec2-user
Group=ec2-user
WorkingDirectory=/home/ec2-user/devbloom/api
EnvironmentFile=/home/ec2-user/devbloom/api/.env
ExecStart=/home/ec2-user/devbloom/api/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
