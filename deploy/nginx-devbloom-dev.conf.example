# Nginx config for DevBloom — dev.funbloomstudio.com (EC2).
# A record: dev.funbloomstudio.com → your EC2 IP.
# Copy to /etc/nginx/conf.d/devbloom.conf (or sites-available on Ubuntu).
# Then: sudo nginx -t
# If nginx isn't running: sudo systemctl start nginx (or sudo systemctl enable --now nginx)
# For config changes later: sudo systemctl reload nginx
# HTTPS: sudo certbot --nginx -d dev.funbloomstudio.com
#
# 502 on https://dev.funbloomstudio.com/api/... but the site loads:
#   Certbot often adds a separate server { listen 443 ssl; ... } block. That block MUST
#   include the same "location /api/ { ... proxy_pass http://127.0.0.1:8000/; ... }" as
#   below. If 443 only proxies "/" to port 3000, /api/* hits Next (wrong) or fails → 502.
#   Fix: sudo nano /etc/nginx/conf.d/devbloom.conf — duplicate /api/ into the ssl server,
#   then sudo nginx -t && sudo systemctl reload nginx
#   Also set client_max_body_size 32m; in each server { } block (HTTP + HTTPS) or image import → 413.
#   Image generate/edit can exceed 60s — set proxy_read_timeout on location /api/ or edit → 504.

#   If HTTPS returns 502 for /api/, duplicate location /api/ into the ssl server block.
#   Same for location /downloads/ after certbot (artist Local Agent zip).

# Same domain, path-based: web at dev.funbloomstudio.com/, API at dev.funbloomstudio.com/api/
server {
    listen 80;
    server_name dev.funbloomstudio.com;

    # Image import and other uploads (API allows up to 25 MB; default nginx limit is 1 MB → 413).
    client_max_body_size 32m;

    # Artist Local Agent zip (private S3 → synced to disk by ec2-deploy.sh)
    location /downloads/ {
        alias /home/ec2-user/github/devbloom/downloads/;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:8000/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffering off;
        # Default read timeout is 60s; OpenAI/Gemini image gen+edit often takes longer.
        proxy_connect_timeout 60s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;
    }
}
